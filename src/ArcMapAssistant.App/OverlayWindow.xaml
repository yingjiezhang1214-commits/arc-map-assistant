<Window x:Class="ArcMapAssistant.App.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Arc Map Overlay"
        Width="2560"
        Height="1440"
        Left="0"
        Top="0"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        ShowActivated="False">
    <Grid Background="Transparent"
          IsHitTestVisible="False">
        <Canvas x:Name="MarkerCanvas"
                Background="Transparent"
                IsHitTestVisible="False" />

        <Border x:Name="DebugCoordinatePanel"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="16"
                Padding="8,5"
                Background="#B0000000"
                CornerRadius="4"
                Visibility="Collapsed">
            <TextBlock x:Name="DebugCoordinateText"
                       Foreground="White"
                       FontFamily="Consolas"
                       FontSize="14"
                       Text="X: 0  Y: 0" />
        </Border>
    </Grid>
</Window>
